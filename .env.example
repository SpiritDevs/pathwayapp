# Optional: pathwayOS Connect source builds
# Leave these unset to disable optional pathwayOS Connect features in local source builds.
# Release builds inject their public values at build time. Do not add server-side
# secrets to this file.

# Get these from the Clerk Dashboard under API keys, JWT templates, and OAuth applications.
# PATHWAYOS_CLERK_PUBLISHABLE_KEY=pk_test_...
# PATHWAYOS_CLERK_JWT_TEMPLATE=pathwayos-relay
# PATHWAYOS_CLERK_CLI_OAUTH_CLIENT_ID=oauthapp_...

# Public Convex deployment origin used by authenticated web, desktop, and mobile clients.
# PATHWAYOS_CONVEX_URL=https://example.convex.cloud

# Optional: signed macOS passkey builds. The RP domain defaults to the Frontend API
# hostname encoded in PATHWAYOS_CLERK_PUBLISHABLE_KEY. Set the override only when Clerk
# returns a different RP ID or when multiple domains must be entitled.
# PATHWAYOS_APPLE_TEAM_ID=ABC1234567
# PATHWAYOS_MACOS_PROVISIONING_PROFILE=/absolute/path/to/pathwayos.provisionprofile
# PATHWAYOS_CLERK_PASSKEY_RP_DOMAINS=example.clerk.accounts.dev,clerk.example.com

# Get this from your Connect HTTP deployment. Convex normally uses the matching
# *.convex.site HTTP Actions origin; the relay name remains a compatibility alias.
# PATHWAYOS_CONNECT_URL=https://example.convex.site

# Public, ingest-only mobile OpenTelemetry configuration.
# PATHWAYOS_MOBILE_OTLP_TRACES_URL=https://api.axiom.co/v1/traces
# PATHWAYOS_MOBILE_OTLP_TRACES_DATASET=pathwayos-mobile-traces-dev
# PATHWAYOS_MOBILE_OTLP_TRACES_TOKEN=xaat-...
